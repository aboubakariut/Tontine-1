{
  "version": 2,
  "functions": {
    "api/api.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/api\\.php(.*)", "dest": "/api/api.php" },
    { "src": "/api/api\\.php(.*)", "dest": "/api/api.php" },
    { "src": "/sw\\.js", "dest": "/sw.js", "headers": { "Service-Worker-Allowed": "/", "Cache-Control": "no-cache" } },
    { "src": "/style\\.css", "dest": "/style.css" },
    { "src": "/app\\.js", "dest": "/app.js" },
    { "src": "/improvements\\.js", "dest": "/improvements.js" },
    { "src": "/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/api.php",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
